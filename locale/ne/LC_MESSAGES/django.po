msgstr "ब्रान्डेड QR मेनु — ३ थिम × ३ लेआउट"

#: core/views.py:56
msgid "Guest ordering + live order queue"
msgstr "पाहुना अर्डर + लाइभ अर्डर लाइन"

#: core/views.py:57
