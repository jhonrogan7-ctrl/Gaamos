# Dev defaults below. For the gaamos.io production deploy, see the
# "Production (gaamos.io)" block at the bottom of this file.
DEBUG=1
SECRET_KEY=django-insecure-dev-only-change-me
# For subdomain-per-tenant dev use: ALLOWED_HOSTS=.localhost,.zxyn.online,localhost,127.0.0.1
ALLOWED_HOSTS=*
# Tenant resolution: <slug>.<BASE_DOMAIN> (and <slug>.localhost in dev) maps to a Company.
# The bare apex + reserved subdomains (app/www/gaamos/…) serve the marketing landing.
BASE_DOMAIN=zxyn.online
# Guest menu anti-enumeration throttle (per IP)
GUEST_RATE_LIMIT=120
GUEST_RATE_WINDOW=60
POSTGRES_DB=gaamos
POSTGRES_USER=gaamos
POSTGRES_PASSWORD=gaamos
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Cloudflare Tunnel token — only needed when running the `edge` profile
TUNNEL_TOKEN=

# ── Production (gaamos.io) ──────────────────────────────────────────────
# Override the dev values above with these on the gaamos.io box. The landing
# serves on the bare apex (no tenant resolved); venue menus on *.gaamos.io.
#   DEBUG=0
#   SECRET_KEY=<a real, unique 50+ char secret>
#   ALLOWED_HOSTS=gaamos.io,.gaamos.io
#   BASE_DOMAIN=gaamos.io
# CSRF_TRUSTED_ORIGINS defaults to "https://gaamos.io,https://*.gaamos.io"
# (apex + subdomains) from BASE_DOMAIN; only set it to override that.
#   CSRF_TRUSTED_ORIGINS=https://gaamos.io,https://*.gaamos.io
# Point the prod Cloudflare tunnel: apex gaamos.io + *.gaamos.io -> web:8000.
# Use a strong POSTGRES_PASSWORD (not the dev default).
